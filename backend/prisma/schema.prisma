
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ComponentType {
  CPU
  GPU
  RAM
  MOTHERBOARD
  SSD
}

model Component {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  category  ComponentType
  price     Float
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
